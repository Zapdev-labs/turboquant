{
  "name": "turboquant",
  "version": "0.2.5",
  "description": "TurboQuant: Extreme compression for AI models with GGUF and SafeTensors export",
  "main": "index.js",
  "bin": {
    "turboquant": "bin/turboquant",
    "tq": "bin/tq"
  },
  "files": [
    "bin/",
    "src/",
    "dist/",
    "index.js",
    "install.js",
    "README.md"
  ],
  "scripts": {
    "install": "node install.js",
    "test": "node test.js",
    "tui": "bun src/tui.tsx",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "postinstall": "echo 'TurboQuant installed. Run: tq (interactive TUI) or turboquant --help'"
  },
  "keywords": [
    "quantization",
    "compression",
    "llm",
    "ai",
    "machine-learning",
    "kv-cache",
    "gguf",
    "safetensors",
    "turboquant"
  ],
  "author": "TurboQuant Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zapdev-labs/turboquant.git"
  },
  "bugs": {
    "url": "https://github.com/zapdev-labs/turboquant/issues"
  },
  "homepage": "https://github.com/zapdev-labs/turboquant",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "@opentui/core": "^0.1.92",
    "@opentui/react": "^0.1.92",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
