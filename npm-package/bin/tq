#!/usr/bin/env node

const path = require('path');
const { spawn, spawnSync } = require('child_process');
const os = require('os');

// Color codes for terminal output
const RESET = '\x1b[0m';
const BOLD = '\x1b[1m';
const DIM = '\x1b[2m';
const PURPLE = '\x1b[38;5;141m';
const VIOLET = '\x1b[38;5;93m';
const GREEN = '\x1b[32m';
const YELLOW = '\x1b[33m';
const RED = '\x1b[31m';
const CYAN = '\x1b[36m';

// Print the TurboQuant logo
function printLogo() {
  console.log('');
  console.log(`${VIOLET}  в–€в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в•—   в–€в–€в•—в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•—  в–€в–€в–€в–€в–€в–€в•— ${RESET}`);
  console.log(`${VIOLET}  в•љв•ђв•ђв–€в–€в•”в•ђв•ђв•ќв–€в–€в•‘   в–€в–€в•‘в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв–€в–€в•—${RESET}`);
  console.log(`${PURPLE}     в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в•‘   в–€в–€в•‘${RESET}`);
  console.log(`${PURPLE}     в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•‘в–„в–„ в–€в–€в•‘${RESET}`);
  console.log(`     в–€в–€в•‘   в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в•‘  в–€в–€в•‘в–€в–€в–€в–€в–€в–€в•”в•ќв•љв–€в–€в–€в–€в–€в–€в•”в•ќ`);
  console.log(`     в•љв•ђв•ќ    в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ќ  в•љв•ђв•ќв•љв•ђв•ђв•ђв•ђв•ђв•ќ  в•љв•ђв•ђв–Ђв–Ђв•ђв•ќ `);
  console.log(`${DIM}  в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ Extreme AI Model Compression в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}`);
  console.log('');
}

// Find Bun executable
function findBun() {
  const candidates = [
    'bun',
    path.join(os.homedir(), '.bun', 'bin', 'bun'),
    '/usr/local/bin/bun',
    '/opt/homebrew/bin/bun',
    '/home/linuxbrew/.linuxbrew/bin/bun',
    '/usr/bin/bun',
    '/bin/bun',
  ];

  for (const cmd of candidates) {
    const result = spawnSync(cmd, ['--version'], { stdio: 'ignore', shell: false });
    if (result.status === 0) return cmd;
  }

  // Last resort: try via shell
  const result = spawnSync('bun', ['--version'], { stdio: 'ignore', shell: true });
  if (result.status === 0) return 'bun';

  return null;
}

// Resolve TUI path - handles various installation layouts (npm, bun, symlinks)
function resolveTuiPath() {
  const fs = require('fs');
  
  // Resolve the actual directory (in case of symlinks)
  let binDir;
  try {
    binDir = fs.realpathSync(__dirname);
  } catch {
    binDir = __dirname;
  }
  
  const packageDir = path.join(binDir, '..');
  
  // Try multiple possible locations
  const candidates = [
    // Compiled JS version (preferred - works with any runtime)
    path.join(packageDir, 'dist', 'tui.js'),
    // Source TypeScript version (requires Bun)
    path.join(packageDir, 'src', 'tui.tsx'),
    // Alternative: current working directory relative (for development)
    path.join(process.cwd(), 'src', 'tui.tsx'),
    // Global bun install location patterns
    path.join(binDir, '..', '..', 'src', 'tui.tsx'),
    path.join(binDir, '..', '..', 'dist', 'tui.js'),
  ];
  
  for (const candidate of candidates) {
    try {
      if (fs.existsSync(candidate)) {
        return candidate;
      }
    } catch {}
  }
  
  return null;
}

// Find Python executable
function findPython() {
  for (const cmd of ['python3', 'python', 'py']) {
    try {
      spawnSync(cmd, ['--version'], { stdio: 'ignore' });
      return cmd;
    } catch {}
  }
  return null;
}

// Check if we should launch TUI (no arguments provided)
const shouldLaunchTUI = process.argv.length <= 2;

// Launch TUI if no arguments provided
if (shouldLaunchTUI) {
  const bunPath = findBun();
  
  if (bunPath) {
    const tuiPath = resolveTuiPath();
    
    if (!tuiPath) {
      printLogo();
      console.error(`${RED}Error: Could not find TUI files${RESET}`);
      console.error('');
      console.error('The following paths were checked:');
      const fs = require('fs');
      let binDir;
      try { binDir = fs.realpathSync(__dirname); } catch { binDir = __dirname; }
      console.error(`  - ${path.join(binDir, '..', 'dist', 'tui.js')}`);
      console.error(`  - ${path.join(binDir, '..', 'src', 'tui.tsx')}`);
      console.error('');
      console.error('This may happen if:');
      console.error('  - The package was installed without including source files');
      console.error('  - There is a symlink resolution issue');
      console.error('');
      console.log(`${DIM}Falling back to CLI mode...${RESET}\n`);
    } else {
      const isCompiled = tuiPath.endsWith('.js');
      const args = isCompiled ? [tuiPath] : [tuiPath];
      
      // Prefer Bun for TUI since @opentui library works best with Bun
      // Bun can run both .js and .tsx files directly
      const runtime = bunPath;
      
      const child = spawn(runtime, args, { 
        stdio: 'inherit', 
        env: process.env,
        shell: false
      });
      
      child.on('exit', (code) => {
        process.exit(code || 0);
      });
      
      return; // Exit early, child process handles the rest
    }
  }
  
  // Bun not available - show helpful message
  printLogo();
  console.log(`${YELLOW}вљ пёЏ  Interactive TUI requires Bun runtime${RESET}\n`);
  console.log('Install Bun for the best experience:');
  console.log(`  ${CYAN}curl -fsSL https://bun.sh/install | bash${RESET}\n`);
  console.log(`${DIM}Falling back to CLI mode...${RESET}\n`);
  
  // Small delay so user can read the message
  const start = Date.now();
  while (Date.now() - start < 1500) {
    // Blocking wait
  }
}

// CLI Mode - delegate to turboquant
const turboquantPath = path.join(__dirname, 'turboquant');
const args = process.argv.slice(2);

// If we have Python, use the full CLI, otherwise show error
const python = findPython();

if (!python) {
  console.error(`${RED}Error: Python not found. Please install Python 3.8+${RESET}`);
  console.error('');
  console.error('Install Python:');
  console.error(`  macOS:    ${CYAN}brew install python${RESET}`);
  console.error(`  Ubuntu:   ${CYAN}sudo apt install python3 python3-pip${RESET}`);
  console.error(`  Windows:  ${CYAN}https://python.org/downloads${RESET}`);
  console.error('');
  console.error('Then install TurboQuant:');
  console.error(`  ${CYAN}pip install turboquant${RESET}`);
  process.exit(1);
}

// Run turboquant CLI with any arguments
const child = spawn(process.execPath, [turboquantPath, ...args], {
  stdio: 'inherit',
  shell: false
});

child.on('exit', (code) => {
  process.exit(code || 0);
});
